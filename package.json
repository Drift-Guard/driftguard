{
  "name": "driftguard",
  "version": "0.3.0",
  "description": "Local JSON schema diff CLI and MCP client for DriftGuard — offline diff + hosted monitoring connector",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kioie/driftguard.git"
  },
  "homepage": "https://github.com/kioie/driftguard#readme",
  "bugs": {
    "url": "https://github.com/kioie/driftguard/issues"
  },
  "keywords": [
    "mcp",
    "schema",
    "drift",
    "api-monitoring",
    "json-schema",
    "model-context-protocol"
  ],
  "bin": {
    "driftguard": "./dist/cli/check.js",
    "driftguard-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "AGENTS.md",
    "SYSTEM_PROMPT.md",
    "server.json",
    "examples/mcp-client-config.json"
  ],
  "scripts": {
    "build": "tsc",
    "dev:mcp": "tsx src/mcp/server.ts",
    "mcp": "node dist/mcp/server.js",
    "check": "tsx src/cli/check.ts",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "test:coverage": "c8 node --import tsx --test 'src/**/*.test.ts'"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "c8": "^10.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
