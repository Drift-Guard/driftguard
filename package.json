{
  "name": "@drift-guard/driftguard",
  "version": "0.3.4",
  "publishConfig": {
    "access": "public"
  },
  "description": "Local JSON schema diff CLI and MCP client for DriftGuard — offline diff + hosted monitoring connector",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Drift-Guard/driftguard.git"
  },
  "homepage": "https://github.com/Drift-Guard/driftguard#readme",
  "bugs": {
    "url": "https://github.com/Drift-Guard/driftguard/issues"
  },
  "keywords": [
    "mcp",
    "schema",
    "drift",
    "api-monitoring",
    "json-schema",
    "model-context-protocol"
  ],
  "bin": {
    "driftguard": "./dist/cli/check.js",
    "driftguard-mcp": "./dist/mcp/server.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "AGENTS.md",
    "SYSTEM_PROMPT.md",
    "server.json",
    "examples/mcp-client-config.json"
  ],
  "scripts": {
    "build": "npm run build --prefix packages/diff-core && tsc",
    "sync-version": "node scripts/sync-version.mjs",
    "dev:mcp": "tsx src/mcp/server.ts",
    "mcp": "node dist/mcp/server.js",
    "check": "tsx src/cli/check.ts",
    "check:agents-yaml": "npm run build && node scripts/check-agents-yaml.mjs",
    "check:npm-publish": "node scripts/npm-publish-prep.mjs",
    "check:server-json": "node scripts/check-server-json.mjs",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "test:coverage": "c8 --reporter=text --reporter=lcov --include='src/core/**' --include='src/mcp/**' node --import tsx --test 'src/**/*.test.ts'",
    "ci:local": "bash scripts/ci-local.sh",
    "sonar:local": "bash scripts/sonar-local.sh",
    "prepush": "npm run ci:local"
  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@drift-guard/diff-core": "file:packages/diff-core",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "yaml": "^2.9.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "c8": "^10.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2"
  }
}
