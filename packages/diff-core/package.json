{
  "name": "@driftguard/diff-core",
  "version": "0.1.0",
  "description": "Canonical schema diff semantics for DriftGuard CLI, hosted checks, and contract tests",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "contract"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contract/vectors.json": "./contract/vectors.json"
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run build && node --test tests/*.test.ts"
  },
  "devDependencies": {
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
