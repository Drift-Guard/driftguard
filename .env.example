# DriftGuard environment variables

# Server
PORT=3000
DRIFTGUARD_DB=./driftguard.db
CRON_SECRET=change-me-in-production
DISABLE_SCHEDULER=0

# Lemon Squeezy (Kenya-friendly MoR — see PAYMENTS_KENYA.md)
